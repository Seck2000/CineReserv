@model IEnumerable<CineReserv.Models.PanierItem>

@{
    ViewData["Title"] = "Mon Panier";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">🛒 Mon Panier</h1>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <h3>Votre panier est vide</h3>
                    <p class="text-muted">Ajoutez des films à votre panier pour commencer vos réservations</p>
                    <a asp-controller="Films" asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-film"></i> Voir les films
                    </a>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-md-8">
                        @foreach (var item in Model)
                        {
                            <div class="card mb-3">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <img src="@item.Seance.Film.ImageUrl" class="img-fluid rounded" alt="@item.Seance.Film.Titre">
                                        </div>
                                        <div class="col-md-6">
                                            <h5>@item.Seance.Film.Titre</h5>
                                            <p class="text-muted">
                                                <strong>Salle :</strong> @item.Seance.Salle.Nom<br>
                                                <strong>Date :</strong> @item.Seance.DateHeure.ToString("dddd dd MMMM yyyy")<br>
                                                <strong>Heure :</strong> @item.Seance.DateHeure.ToString("HH:mm")<br>
                                                <strong>Prix unitaire :</strong> @item.PrixUnitaire.ToUsdString()
                                            </p>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-2">
                                                <strong>Nombre de places : @item.Quantite</strong>
                                            </div>
                                            @if (!string.IsNullOrEmpty(item.SiegeIds))
                                            {
                                                <div class="mb-2">
                                                    <strong>Sièges :</strong>
                                                    @{
                                                        var siegeIds = item.SiegeIds.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                                        var siegesNoms = new List<string>();
                                                        if (item.Seance?.Salle?.Sieges != null)
                                                        {
                                                            foreach (var siegeIdStr in siegeIds)
                                                            {
                                                                if (int.TryParse(siegeIdStr.Trim(), out var siegeId))
                                                                {
                                                                    var siege = item.Seance.Salle.Sieges.FirstOrDefault(s => s.Id == siegeId);
                                                                    if (siege != null)
                                                                    {
                                                                        siegesNoms.Add(siege.NomComplet);
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                    @if (siegesNoms.Any())
                                                    {
                                                        <div class="d-flex flex-wrap gap-1 mt-1">
                                                            @foreach (var siegeNom in siegesNoms)
                                                            {
                                                                <span class="badge bg-primary">@siegeNom</span>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">Sièges non disponibles</span>
                                                    }
                                                </div>
                                            }
                                            <div class="mb-2">
                                                <strong>Total : @item.PrixTotal.ToUsdString()</strong>
                                            </div>
                                            <form method="post" asp-action="Supprimer" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="fas fa-trash"></i> Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-header">
                                <h5>Récapitulatif</h5>
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Nombre d'articles :</span>
                                    <strong>@Model.Count()</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Total des places :</span>
                                    <strong>@Model.Sum(i => i.Quantite)</strong>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between mb-3">
                                    <span><strong>Total à payer :</strong></span>
                                    <strong class="h5 text-primary">@Model.Sum(i => i.PrixTotal).ToUsdString()</strong>
                                </div>
                                
                                <div class="d-grid gap-2">
                                    <a asp-controller="Payment" asp-action="Index" class="btn btn-success btn-lg">
                                        <i class="fas fa-credit-card"></i> Procéder au paiement
                                    </a>
                                    <form method="post" asp-action="Vider" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger w-100" 
                                                onclick="return confirm('Êtes-vous sûr de vouloir vider votre panier ?')">
                                            <i class="fas fa-trash"></i> Vider le panier
                                        </button>
                                    </form>
                                    <a asp-controller="Films" asp-action="Index" class="btn btn-outline-primary">
                                        <i class="fas fa-plus"></i> Continuer mes réservations
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
